# Python bytecode cache
__pycache__/
*.pyc
*.pyo

# Virtual environment
.venv/
venv/
env/

# IDE
.idea/

# Claude Code
.claude/

# Uploaded images (temporary)
static/uploads/*.jpg
static/uploads/*.png
static/uploads/*.jpeg
static/uploads/*.gif
static/uploads/*.bmp
static/uploads/*.webp

# Model checkpoints / serialized models (~50+ MB — too large for git)
models/*.pth
*.pth
*.pkl

# Large JSON / data files
**/data/*.json
*.json.zip

# Raw & processed dataset images (8k+ images, ~350 MB)
data/raw/
data/dataset/

# Generated outputs (regenerate on demand)
results/*.png

# OS files
Thumbs.db
.DS_Store
Desktop.ini

# 拦截大数据作业可能生成的垃圾文件
# 过滤 Spark 运行生成的 derby.log 和 metastore_db
derby.log
metastore_db/
spark-warehouse/

# 过滤各种常见的大数据格式及中间结果
*.dat
*.data
*.csv
*.tsv
*.parquet

# 过滤大作业产生的各种编译和打包产物
target/
*.jar
.bsp/